{
  "name": "cvwfs-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @cvwfs/frontend\" \"npm run dev -w @cvwfs/backend\"",
    "dev:frontend": "npm run dev -w @cvwfs/frontend",
    "dev:backend": "npm run dev -w @cvwfs/backend",
    "build": "npm run build -w @cvwfs/frontend",
    "lint": "npm run lint --workspaces --if-present",
    "preview": "npm run preview -w @cvwfs/frontend",
    "start": "npm run start -w @cvwfs/backend"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
